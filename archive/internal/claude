const NODE_MAP = {}; NODES.forEach(n => NODE_MAP[n.id] = n);
const TOTAL_TIME = Math.max(...NODES.map(n => n.start + n.duration));
const MAX_DUR = Math.max(...NODES.map(n => n.duration));

// ─── Components ──────────────────────────────────────────

function GraphNode({ node, selected, hovered, onSelect, onHover, playhead, zoom, pan }) {
  const pipe = PIPE[node.pipeline];
  const unit = UNIT[node.unit];
  const isSel = selected === node.id;
  const isHov = hovered === node.id;
  const isAct = isSel || isHov;
  const durFrac = node.duration / MAX_DUR;
  const heat = heatColor(durFrac);
  const pctTotal = ((node.duration / TOTAL_TIME) * 100).toFixed(1);
  const endTime = node.start + node.duration;

  // Execution progress
  let progress = 0;
  let execState = "pending";
  if (playhead !== null) {
    if (playhead >= endTime) { progress = 1; execState = "done"; }
    else if (playhead > node.start) { progress = (playhead - node.start) / node.duration; execState = "running"; }
  }

  const nodeLines = node.name.split("\n");

  return (
    <g onClick={(e) => { e.stopPropagation(); onSelect(isSel ? null : node.id); }}
       onMouseEnter={() => onHover(node.id)} onMouseLeave={() => onHover(null)}
       style={{ cursor: "pointer" }}>

      {/* Outer glow on selection */}
      {isAct && (
        <rect x={node.x - 3} y={node.y - 3} width={node.w + 6} height={node.h + 6} rx={10}
          fill="none" stroke={pipe.accent} strokeWidth={1.5} opacity={0.5}
          style={{ filter: `drop-shadow(0 0 10px ${pipe.accent}60)` }} />
      )}

      {/* Main body */}
      <rect x={node.x} y={node.y} width={node.w} height={node.h} rx={7}
        fill={isAct ? pipe.bg : unit.bg}
        stroke={isAct ? pipe.accent : node.status === "warning" ? "#F59E0B" : unit.border + "60"}
        strokeWidth={isAct ? 1.5 : 0.8} />

      {/* Pipeline accent stripe (top) */}
      <rect x={node.x + 5} y={node.y} width={node.w - 10} height={2.5} rx={1}
        fill={pipe.accent} opacity={0.8} />

      {/* Duration heat bar (bottom) — width proportional to duration fraction */}
      <rect x={node.x + 1} y={node.y + node.h - 5} width={(node.w - 2) * durFrac} height={4} rx={2}
        fill={heat} opacity={0.7} />
      {/* Heat bar background */}
      <rect x={node.x + 1} y={node.y + node.h - 5} width={node.w - 2} height={4} rx={2}
        fill="#FFFFFF" opacity={0.04} />

      {/* Execution progress overlay */}
      {playhead !== null && progress > 0 && (
        <rect x={node.x} y={node.y} width={node.w * progress} height={node.h} rx={7}
          fill={execState === "running" ? pipe.accent : "#FFFFFF"} opacity={execState === "running" ? 0.12 : 0.05}
          style={{ pointerEvents: "none" }} />
      )}

      {/* Running indicator pulse */}
      {execState === "running" && (
        <rect x={node.x} y={node.y} width={node.w} height={node.h} rx={7}
          fill="none" stroke={pipe.accent} strokeWidth={1.5} opacity={0.6}
          style={{ animation: "none" }} />
      )}

      {/* Warning indicator */}
      {node.status === "warning" && (
        <g>
          <rect x={node.x + node.w - 20} y={node.y + 4} width={16} height={14} rx={3}
            fill="#78350F" stroke="#F59E0B" strokeWidth={0.6} />
          <text x={node.x + node.w - 12} y={node.y + 13} fill="#FBBF24" fontSize={9}
            textAnchor="middle" fontWeight="700">!</text>
        </g>
      )}

      {/* Core badge (top-left) */}
      <rect x={node.x + 4} y={node.y + 6} width={node.core.length * 5.2 + 8} height={13} rx={3}
        fill={node.unit === "cube" ? "#A855F720" : "#22C55E20"} />
      <text x={node.x + 8} y={node.y + 15} fill={node.unit === "cube" ? "#C084FC" : "#4ADE80"}
        fontSize={7} fontFamily="'IBM Plex Mono',monospace" fontWeight="600">{node.core}</text>

      {/* Tiles count badge (if applicable) */}
      {node.tiles && (
        <g>
          <rect x={node.x + 4} y={node.y + 22} width={24} height={11} rx={2.5}
            fill={pipe.accent + "25"} stroke={pipe.accent + "40"} strokeWidth={0.5} />
          <text x={node.x + 16} y={node.y + 29.5} fill={pipe.h} fontSize={6.5}
            fontFamily="'IBM Plex Mono',monospace" textAnchor="middle" fontWeight="600">×{node.tiles}</text>
        </g>
      )}

      {/* Name */}
      {nodeLines.map((line, i) => (
        <text key={i} x={node.x + node.w / 2} y={node.y + 22 + i * 12}
          fill={isAct ? "#F1F5F9" : unit.text} fontSize={9.5}
          fontFamily="'IBM Plex Mono',monospace" textAnchor="middle" fontWeight="600"
          dominantBaseline="middle">{line}</text>
      ))}

      {/* Timing info (bottom-left) */}
      <text x={node.x + 5} y={node.y + node.h - 9} fill="#64748B" fontSize={6.5}
        fontFamily="'IBM Plex Mono',monospace">
        {node.start.toFixed(2)}→{endTime.toFixed(2)}ms
      </text>

      {/* Duration + % (bottom-right) */}
      <text x={node.x + node.w - 5} y={node.y + node.h - 9} fill={heat} fontSize={7}
        fontFamily="'IBM Plex Mono',monospace" textAnchor="end" fontWeight="600">
        {node.duration.toFixed(3)}ms ({pctTotal}%)
      </text>

      {/* Memory badges */}
      {(node.memR > 0 || node.memW > 0) && (
        <g>
          {node.memR > 0 && (
            <g>
              <rect x={node.x + node.w - 50} y={node.y + 5} width={44} height={11} rx={2.5}
                fill="#06B6D420" />
              <text x={node.x + node.w - 28} y={node.y + 12.5} fill="#67E8F9" fontSize={6}
                fontFamily="'IBM Plex Mono',monospace" textAnchor="middle">R:{(node.memR / 1024).toFixed(0)}K</text>
            </g>
          )}
          {node.memW > 0 && (
            <g>
              <rect x={node.x + node.w - 50} y={node.y + (node.memR > 0 ? 18 : 5)} width={44} height={11} rx={2.5}
                fill="#F59E0B20" />
              <text x={node.x + node.w - 28} y={node.y + (node.memR > 0 ? 25.5 : 12.5)} fill="#FDE68A" fontSize={6}
                fontFamily="'IBM Plex Mono',monospace" textAnchor="middle">W:{(node.memW / 1024).toFixed(0)}K</text>
            </g>
          )}
        </g>
      )}
    </g>
  );
}

function GraphEdge({ edge, nodeMap, selected, hovered, playhead }) {
  const from = nodeMap[edge.from];
  const to = nodeMap[edge.to];
  if (!from || !to) return null;

  const fromEnd = from.start + from.duration;
  const waitTime = Math.max(0, to.start - fromEnd);

  // Highlight if connected to selected/hovered
  const activeId = hovered || selected;
  const isActive = activeId && (edge.from === activeId || edge.to === activeId);
  const isInChain = activeId && (edge.from === activeId || edge.to === activeId);

  // Bezier from right-center of source → left-center of target
  const x1 = from.x + from.w;
  const y1 = from.y + from.h / 2;
  const x2 = to.x;
  const y2 = to.y + to.h / 2;
  const dx = x2 - x1;
  const cp = Math.max(dx * 0.4, 30);

  const fromPipe = PIPE[from.pipeline];

  // Edge done state
  let edgeDone = false;
  if (playhead !== null && playhead >= to.start) edgeDone = true;

  return (
    <g>
      <path
        d={`M${x1},${y1} C${x1 + cp},${y1} ${x2 - cp},${y2} ${x2},${y2}`}
        fill="none"
        stroke={isActive ? fromPipe.accent : edgeDone ? "#334155" : "#1E293B"}
        strokeWidth={isActive ? 1.5 : 0.7}
        opacity={activeId ? (isActive ? 1 : 0.12) : 0.4}
        markerEnd={isActive ? "url(#arrow-active)" : "url(#arrow)"}
        strokeDasharray={from.pipeline !== to.pipeline ? "4,3" : "none"}
      />
      {/* Wait time annotation on active edges */}
      {isActive && waitTime > 0.005 && (
        <g>
          <rect x={(x1 + x2) / 2 - 18} y={(y1 + y2) / 2 - 8} width={36} height={14} rx={3}
            fill="#0F172A" stroke="#334155" strokeWidth={0.5} />
          <text x={(x1 + x2) / 2} y={(y1 + y2) / 2 + 0.5} fill="#F59E0B" fontSize={7}
            fontFamily="'IBM Plex Mono',monospace" textAnchor="middle" dominantBaseline="middle">
            +{waitTime.toFixed(2)}ms
          </text>
        </g>
      )}
    </g>
  );
}

// ─── Inspector ───────────────────────────────────────────
function Inspector({ nodeId }) {
  const node = nodeId ? NODE_MAP[nodeId] : null;
  if (!node) return (
    <div style={{ padding: 20, textAlign: "center", color: "#334155", fontSize: 10, fontFamily: "'IBM Plex Mono',monospace" }}>
      <div style={{ fontSize: 24, marginBottom: 8, opacity: 0.25 }}>⬡</div>
      Click any node to inspect<br/>
      <span style={{ fontSize: 8, color: "#1E293B" }}>Hover to preview dependencies</span>
    </div>
  );
  const pipe = PIPE[node.pipeline];
  const unit = UNIT[node.unit];
  const endTime = node.start + node.duration;

  // Find deps and consumers
  const deps = EDGES.filter(e => e.to === node.id).map(e => NODE_MAP[e.from]).filter(Boolean);
  const consumers = EDGES.filter(e => e.from === node.id).map(e => NODE_MAP[e.to]).filter(Boolean);

  return (
    <div style={{ padding: 12, fontSize: 9, fontFamily: "'IBM Plex Mono',monospace" }}>
      <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 8 }}>
        <div style={{ width: 4, height: 22, borderRadius: 2, background: pipe.accent }} />
        <div>
          <div style={{ color: "#F1F5F9", fontSize: 12, fontWeight: 700 }}>{node.name.replace("\n", " ")}</div>
          <div style={{ display: "flex", gap: 4, marginTop: 3 }}>
            <span style={{ fontSize: 7, color: pipe.h, background: pipe.dim, padding: "2px 6px", borderRadius: 3 }}>{node.pipeline.toUpperCase()}</span>
            <span style={{ fontSize: 7, color: unit.text, background: unit.bg, padding: "2px 6px", borderRadius: 3, border: `1px solid ${unit.border}30` }}>{unit.label}</span>
            <span style={{ fontSize: 7, color: "#94A3B8", background: "#1E293B", padding: "2px 6px", borderRadius: 3 }}>{node.core}</span>
          </div>
        </div>
      </div>

      {node.status === "warning" && (
        <div style={{ padding: "5px 7px", background: "#451A0320", border: "1px solid #92400E40", borderRadius: 5, color: "#FBBF24", fontSize: 8, marginBottom: 8, lineHeight: 1.5 }}>
          ⚠ Duration anomaly detected — tiles T3, T7 slow
        </div>
      )}

      <div style={{ color: "#64748B", fontSize: 8, marginBottom: 10, lineHeight: 1.6, padding: "5px 0", borderTop: "1px solid #151D2E", borderBottom: "1px solid #151D2E" }}>
        {node.desc}
      </div>

      {/* Timing detail */}
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 4, marginBottom: 10 }}>
        {[
          ["Start", `${node.start.toFixed(3)} ms`],
          ["End", `${endTime.toFixed(3)} ms`],
          ["Duration", `${node.duration.toFixed(3)} ms`],
          ["% of Total", `${((node.duration / TOTAL_TIME) * 100).toFixed(1)}%`],
          ["Core", node.core],
          ["Unit", node.unit.toUpperCase()],
          ...(node.memR > 0 ? [["Mem Read", `${node.memR} KB`]] : []),
          ...(node.memW > 0 ? [["Mem Write", `${node.memW} KB`]] : []),
          ...(node.tiles ? [["Tiles", `${node.tiles} parallel`]] : []),
        ].map(([k, v]) => (
          <div key={k} style={{ padding: "4px 6px", background: "#0C1018", borderRadius: 4, border: "1px solid #151D2E" }}>
            <div style={{ color: "#334155", fontSize: 7 }}>{k}</div>
            <div style={{ color: pipe.h, fontSize: 9, fontWeight: 500 }}>{v}</div>
          </div>
        ))}
      </div>

      {/* Inline waterfall bar */}
      <div style={{ marginBottom: 10 }}>
        <div style={{ fontSize: 7, color: "#334155", letterSpacing: "0.08em", marginBottom: 4 }}>EXECUTION TIMELINE</div>
        <div style={{ position: "relative", height: 14, background: "#0C1018", borderRadius: 3, border: "1px solid #151D2E", overflow: "hidden" }}>
          <div style={{
            position: "absolute",
            left: `${(node.start / TOTAL_TIME) * 100}%`,
            width: `${Math.max((node.duration / TOTAL_TIME) * 100, 1)}%`,
            height: "100%",
            background: `linear-gradient(90deg, ${pipe.accent}, ${heatColor(node.duration / MAX_DUR)})`,
            borderRadius: 2,
          }} />
          <div style={{ position: "absolute", left: `${(node.start / TOTAL_TIME) * 100 + 2}%`, top: 1, fontSize: 7, color: "#FFF", fontWeight: 600 }}>
            {node.duration.toFixed(3)}ms
          </div>
        </div>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: 2, fontSize: 7, color: "#1E293B" }}>
          <span>0ms</span><span>{TOTAL_TIME.toFixed(2)}ms</span>
        </div>
      </div>

      {deps.length > 0 && (
        <div style={{ marginBottom: 8 }}>
          <div style={{ color: "#334155", fontSize: 7, letterSpacing: "0.08em", marginBottom: 3 }}>DEPENDS ON ({deps.length})</div>
          <div style={{ display: "flex", flexWrap: "wrap", gap: 3 }}>
            {deps.map(d => {
              const dp = PIPE[d.pipeline];
              return <span key={d.id} style={{ padding: "2px 6px", background: dp.dim, border: `1px solid ${dp.accent}30`, borderRadius: 3, color: dp.h, fontSize: 7.5, cursor: "pointer" }}>{d.name.replace("\n", " ")}</span>;
            })}
          </div>
        </div>
      )}
      {consumers.length > 0 && (
        <div>
          <div style={{ color: "#334155", fontSize: 7, letterSpacing: "0.08em", marginBottom: 3 }}>FEEDS INTO ({consumers.length})</div>
          <div style={{ display: "flex", flexWrap: "wrap", gap: 3 }}>
            {consumers.map(d => {
              const dp = PIPE[d.pipeline];
              return <span key={d.id} style={{ padding: "2px 6px", background: dp.dim, border: `1px solid ${dp.accent}30`, borderRadius: 3, color: dp.h, fontSize: 7.5, cursor: "pointer" }}>{d.name.replace("\n", " ")}</span>;
            })}
          </div>
        </div>
      )}
    </div>
  );
}

// ─── Main App ────────────────────────────────────────────
function App() {
  const [selected, setSelected] = useState(null);
  const [hovered, setHovered] = useState(null);
  const [playhead, setPlayhead] = useState(null);
  const [isPlaying, setIsPlaying] = useState(false);
  const [zoom, setZoom] = useState(0.85);
  const animRef = useRef(null);
  const startRef = useRef(null);

  // Dimming: compute connected set
  const activeId = hovered || selected;
  const connectedNodes = useMemo(() => {
    if (!activeId) return new Set();
    const s = new Set([activeId]);
    const vU = new Set(), vD = new Set();
    const up = (id) => { if (vU.has(id)) return; vU.add(id); s.add(id); EDGES.forEach(e => { if (e.to === id) { s.add(e.from); up(e.from); } }); };
    const dn = (id) => { if (vD.has(id)) return; vD.add(id); s.add(id); EDGES.forEach(e => { if (e.from === id) { s.add(e.to); dn(e.to); } }); };
    up(activeId); dn(activeId);
    return s;
  }, [activeId]);

  // Playback
  useEffect(() => {
    if (!isPlaying) { if (animRef.current) cancelAnimationFrame(animRef.current); return; }
    startRef.current = performance.now() - ((playhead || 0) * 700);
    const tick = (ts) => {
      const e = (ts - startRef.current) / 700;
      if (e >= TOTAL_TIME) { setPlayhead(TOTAL_TIME); setIsPlaying(false); return; }
      setPlayhead(e);
      animRef.current = requestAnimationFrame(tick);
    };
    animRef.current = requestAnimationFrame(tick);
    return () => { if (animRef.current) cancelAnimationFrame(animRef.current); };
  }, [isPlaying]);

  const handleWheel = useCallback((e) => {
    if (e.ctrlKey || e.metaKey) { e.preventDefault(); setZoom(z => Math.max(0.3, Math.min(2.5, z - e.deltaY * 0.002))); }
  }, []);

  const svgW = 1600;
  const svgH = 700;

  const ctrl = { background: "none", border: "1px solid #1E293B", color: "#64748B", fontSize: 13, cursor: "pointer", padding: "3px 7px", borderRadius: 4, fontFamily: "'IBM Plex Mono',monospace" };

  return (
    <div style={{ width: "100%", height: "100vh", background: "#07090F", fontFamily: "'IBM Plex Mono','SF Mono',monospace", display: "flex", flexDirection: "column", overflow: "hidden", color: "#CBD5E1" }}>
      {/* HEADER */}
      <div style={{ height: 42, minHeight: 42, background: "#0C1018", borderBottom: "1px solid #1A2030", display: "flex", alignItems: "center", justifyContent: "space-between", padding: "0 14px" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
          <svg width="18" height="18" viewBox="0 0 16 16"><rect x="1" y="2" width="5" height="5" rx="1.5" fill="#A855F7" opacity="0.8" /><rect x="10" y="2" width="5" height="5" rx="1.5" fill="#10B981" opacity="0.7" /><rect x="5.5" y="9" width="5" height="5" rx="1.5" fill="#F97316" opacity="0.7" /><line x1="3.5" y1="7" x2="8" y2="9" stroke="#334155" strokeWidth="0.8" /><line x1="12.5" y1="7" x2="8" y2="9" stroke="#334155" strokeWidth="0.8" /></svg>
          <span style={{ fontSize: 13, fontWeight: 700, color: "#F1F5F9", letterSpacing: "-0.02em" }}>IndexerPrologQuant</span>
          <span style={{ fontSize: 8, color: "#334155", background: "#0C1018", border: "1px solid #1A2030", padding: "2px 8px", borderRadius: 4 }}>Computation Graph + Execution</span>
          <span style={{ fontSize: 8, color: "#1E293B", padding: "2px 8px" }}>Ascend 910B · {NODES.length} nodes · {TOTAL_TIME.toFixed(3)}ms</span>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
          {/* Heat legend */}
          <div style={{ display: "flex", alignItems: "center", gap: 4, fontSize: 7.5, color: "#475569" }}>
            <span>Fast</span>
            <div style={{ width: 50, height: 5, borderRadius: 3, background: "linear-gradient(90deg, rgb(30,180,220), rgb(130,120,120), rgb(230,60,40))" }} />
            <span>Slow</span>
          </div>
          <div style={{ width: 1, height: 16, background: "#1A2030" }} />
          <div style={{ display: "flex", gap: 6, fontSize: 7.5 }}>
            {[["Query", PIPE.query.accent], ["Key", PIPE.key.accent], ["Weight", PIPE.weight.accent]].map(([l, c]) => (
              <div key={l} style={{ display: "flex", alignItems: "center", gap: 3 }}>
                <div style={{ width: 8, height: 3, borderRadius: 1, background: c }} /><span style={{ color: "#475569" }}>{l}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* MAIN */}
      <div style={{ flex: 1, display: "flex", minHeight: 0 }}>
        {/* Graph */}
        <div style={{ flex: 1, overflow: "auto", position: "relative" }} onWheel={handleWheel} onClick={() => setSelected(null)}>
          {/* Dot grid */}
          <div style={{ position: "absolute", inset: 0, backgroundImage: "radial-gradient(circle, #1A2030 0.8px, transparent 0.8px)", backgroundSize: "20px 20px", opacity: 0.4, pointerEvents: "none" }} />
          <svg width={svgW * zoom} height={svgH * zoom} viewBox={`0 0 ${svgW} ${svgH}`}
            style={{ display: "block", minWidth: "100%", minHeight: "100%" }}>
            <defs>
              <marker id="arrow" markerWidth="6" markerHeight="5" refX="6" refY="2.5" orient="auto"><path d="M0,0L6,2.5L0,5" fill="#334155" /></marker>
              <marker id="arrow-active" markerWidth="7" markerHeight="5" refX="7" refY="2.5" orient="auto"><path d="M0,0L7,2.5L0,5" fill="#94A3B8" /></marker>
            </defs>

            {/* Pipeline region backgrounds */}
            <rect x={200} y={0} width={1350} height={230} rx={12} fill="#A855F708" stroke="#A855F710" strokeWidth={0.5} strokeDasharray="6,4" />
            <text x={215} y={18} fill="#A855F730" fontSize={10} fontFamily="'IBM Plex Mono',monospace" fontWeight="700">QUERY PIPELINE</text>
            <rect x={200} y={340} width={1350} height={260} rx={12} fill="#10B98108" stroke="#10B98110" strokeWidth={0.5} strokeDasharray="6,4" />
            <text x={215} y={358} fill="#10B98130" fontSize={10} fontFamily="'IBM Plex Mono',monospace" fontWeight="700">KEY PIPELINE</text>
            <rect x={360} y={575} width={550} height={105} rx={12} fill="#F9731608" stroke="#F9731610" strokeWidth={0.5} strokeDasharray="6,4" />
            <text x={375} y={593} fill="#F9731630" fontSize={10} fontFamily="'IBM Plex Mono',monospace" fontWeight="700">WEIGHT PIPELINE</text>

            {/* Edges */}
            {EDGES.map((e, i) => (
              <GraphEdge key={i} edge={e} nodeMap={NODE_MAP} selected={selected} hovered={hovered} playhead={playhead} />
            ))}

            {/* Nodes */}
            {NODES.map(n => {
              const dimmed = connectedNodes.size > 0 && !connectedNodes.has(n.id);
              return (
                <g key={n.id} opacity={dimmed ? 0.12 : 1}>
                  <GraphNode node={n} selected={selected} hovered={hovered}
                    onSelect={setSelected} onHover={setHovered} playhead={playhead}
                    zoom={zoom} />
                </g>
              );
            })}
          </svg>
        </div>

        {/* RIGHT SIDEBAR */}
        <div style={{ width: 260, minWidth: 260, background: "#0C1018", borderLeft: "1px solid #1A2030", display: "flex", flexDirection: "column", overflow: "auto" }}>
          <div style={{ borderBottom: "1px solid #151D2E" }}>
            <div style={{ padding: "8px 12px 4px", fontSize: 8, color: "#1E293B", letterSpacing: "0.1em" }}>NODE INSPECTOR</div>
            <Inspector nodeId={selected || hovered} />
          </div>

          {/* Summary stats */}
          <div style={{ padding: 12, borderBottom: "1px solid #151D2E" }}>
            <div style={{ fontSize: 8, color: "#1E293B", letterSpacing: "0.1em", marginBottom: 8 }}>OPERATOR SUMMARY</div>
            {[
              ["Total Nodes", NODES.length],
              ["Cube Ops", NODES.filter(n => n.unit === "cube").length],
              ["Vector Ops", NODES.filter(n => n.unit === "vector").length],
              ["Total Duration", `${TOTAL_TIME.toFixed(3)} ms`],
              ["Critical Path", "Q pipeline"],
              ["AIC Used", "0-20 (21 cores)"],
              ["AIV Used", "0-28 (20 cores)"],
            ].map(([k, v]) => (
              <div key={k} style={{ display: "flex", justifyContent: "space-between", padding: "3px 0", fontSize: 8.5 }}>
                <span style={{ color: "#475569" }}>{k}</span>
                <span style={{ color: "#CBD5E1", fontWeight: 500 }}>{v}</span>
              </div>
            ))}
          </div>

          {/* Diagnostics */}
          <div style={{ padding: 12, flex: 1 }}>
            <div style={{ fontSize: 8, color: "#1E293B", letterSpacing: "0.1em", marginBottom: 8 }}>DIAGNOSTICS</div>
            {[
              { s: "warn", m: "Q:Linear tiles T3,T7 are 18% slower — L2 bank conflict on AIC 3,7" },
              { s: "warn", m: "Q pipeline critical path: 0.818ms (dominates total)" },
              { s: "opt", m: "Fuse Q:NoPE_Cast into Q:Concat to remove dtype round-trip" },
              { s: "opt", m: "K:Rope2D + K:NoPE_Cast → same AIV to save 1 core" },
              { s: "info", m: "Cross-pipeline dependency: Q:View_CosSin → K:Rope2D (shared cos/sin)" },
            ].map((d, i) => (
              <div key={i} style={{
                padding: "5px 7px", marginBottom: 4, borderRadius: 4, fontSize: 8.5, lineHeight: 1.5,
                background: d.s === "warn" ? "#451A0315" : d.s === "opt" ? "#0C2D3E15" : "#1E293B15",
                border: `1px solid ${d.s === "warn" ? "#92400E25" : d.s === "opt" ? "#06B6D425" : "#1E293B25"}`,
                color: d.s === "warn" ? "#FBBF24" : d.s === "opt" ? "#67E8F9" : "#64748B",
              }}>
                {d.s === "warn" ? "⚠ " : d.s === "opt" ? "⚡ " : "ℹ "}{d.m}
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* CONTROLS */}
      <div style={{ height: 40, minHeight: 40, background: "#0C1018", borderTop: "1px solid #1A2030", display: "flex", alignItems: "center", padding: "0 14px", gap: 8 }}>
        <button onClick={() => { setPlayhead(0); setIsPlaying(false); }} style={ctrl}>⏮</button>
        <button onClick={() => setIsPlaying(!isPlaying)} style={{ ...ctrl, color: isPlaying ? "#EF4444" : "#34D399", borderColor: isPlaying ? "#7F1D1D" : "#064E3B" }}>{isPlaying ? "⏸" : "▶"}</button>
        <div style={{ flex: 1, height: 4, background: "#1A2030", borderRadius: 2, cursor: "pointer" }}
          onClick={(e) => { const r = e.currentTarget.getBoundingClientRect(); setPlayhead(((e.clientX - r.left) / r.width) * TOTAL_TIME); }}>
          <div style={{ height: "100%", borderRadius: 2, width: `${((playhead || 0) / TOTAL_TIME) * 100}%`, background: "linear-gradient(90deg, #A855F7, #10B981, #F97316)", transition: isPlaying ? "none" : "width .1s" }} />
        </div>
        <span style={{ fontSize: 9, color: "#475569", minWidth: 90, textAlign: "right" }}>{(playhead || 0).toFixed(3)} / {TOTAL_TIME.toFixed(3)} ms</span>
        <div style={{ width: 1, height: 14, background: "#1A2030" }} />
        <button onClick={() => setZoom(z => Math.min(2.5, z + 0.15))} style={ctrl}>+</button>
        <span style={{ fontSize: 9, color: "#475569", minWidth: 32, textAlign: "center" }}>{Math.round(zoom * 100)}%</span>
        <button onClick={() => setZoom(z => Math.max(0.3, z - 0.15))} style={ctrl}>−</button>
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById("root")).render(<App />);
</script>
</body>
</html>
