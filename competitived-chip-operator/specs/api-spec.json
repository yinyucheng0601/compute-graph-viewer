{
  "version": "0.1.0",
  "modules": {
    "stackDoctor": {
      "inputs": {
        "driverVersion": "string",
        "runtimeVersion": "string",
        "framework": "pytorch | tensorflow | jax | custom",
        "frameworkVersion": "string",
        "gpuSku": "string",
        "containerImage": "string | null"
      },
      "outputs": {
        "supportLevel": "supported | warning | unsupported | unknown",
        "risks": "CompatibilityRisk[]",
        "fixCommands": "string[]",
        "documentationLinks": "string[]"
      }
    },
    "operatorLab": {
      "inputs": {
        "operatorName": "string",
        "targetBackend": "cuda | hip | triton",
        "dtypes": "string[]",
        "shapeFamilies": "ShapeSpec[]",
        "referencePath": "string"
      },
      "outputs": {
        "workspacePath": "string",
        "testReport": "CorrectnessReport",
        "benchmarkReport": "BenchmarkReport",
        "integrationTemplate": "pytorch_extension | custom_runtime"
      }
    },
    "compileExplanation": {
      "inputs": {
        "sourcePath": "string",
        "targetGpu": "string",
        "compilerFlags": "string[]",
        "sampleShape": "Record<string, number>"
      },
      "outputs": {
        "selectedInstructions": "string[]",
        "tileShape": "Record<string, number>",
        "registerEstimate": "number",
        "missedOptimizations": "MissedOptimization[]",
        "irArtifacts": "string[]"
      }
    },
    "profileExperiment": {
      "inputs": {
        "kernelName": "string",
        "baselineProfile": "string",
        "hypothesis": "string",
        "changeSet": "string[]"
      },
      "outputs": {
        "evidenceMetrics": "Metric[]",
        "expectedMetricMovement": "MetricExpectation[]",
        "result": "improved | neutral | regressed | inconclusive",
        "nextAction": "string"
      }
    }
  }
}
