// ─── Pipeline Colors ─────────────────────────────────────
const PIPE = {
  query:  { h: "#C084FC", accent: "#A855F7", bg: "#1C0A3A", dim: "#130828" },
  key:    { h: "#34D399", accent: "#10B981", bg: "#082218", dim: "#051A10" },
  weight: { h: "#FB923C", accent: "#F97316", bg: "#2A1508", dim: "#1A0D04" },
  shared: { h: "#94A3B8", accent: "#64748B", bg: "#1A1F2E", dim: "#12151F" },
};

const UNIT = {
  cube:   { border: "#A855F7", bg: "#18083A", text: "#D8B4FE", label: "CUBE" },
  vector: { border: "#22C55E", bg: "#081E12", text: "#86EFAC", label: "VEC" },
  memory: { border: "#06B6D4", bg: "#082830", text: "#67E8F9", label: "MEM" },
  scatter:{ border: "#F59E0B", bg: "#2A2008", text: "#FDE68A", label: "SCAT" },
};

// ─── Duration heat: fraction of max duration → color ────
function heatColor(fraction) {
  // 0 = cool blue, 0.5 = teal, 1.0 = hot orange/red
  const r = Math.round(30 + fraction * 200);
  const g = Math.round(180 - fraction * 120);
  const b = Math.round(220 - fraction * 180);
  return `rgb(${r},${g},${b})`;
}

