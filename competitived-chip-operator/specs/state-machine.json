{
  "operatorDevelopmentStateMachine": {
    "states": [
      "environment_unknown",
      "environment_validated",
      "reference_ready",
      "kernel_draft",
      "correctness_failed",
      "correctness_passed",
      "profiled",
      "optimized",
      "integrated",
      "regression_guarded"
    ],
    "transitions": [
      {"from": "environment_unknown", "to": "environment_validated", "condition": "stackDoctor.supportLevel is supported or warning accepted"},
      {"from": "environment_validated", "to": "reference_ready", "condition": "reference implementation passes CPU tests"},
      {"from": "reference_ready", "to": "kernel_draft", "condition": "kernel source created"},
      {"from": "kernel_draft", "to": "correctness_failed", "condition": "random or boundary tests fail"},
      {"from": "correctness_failed", "to": "kernel_draft", "condition": "debug route applied and source changed"},
      {"from": "kernel_draft", "to": "correctness_passed", "condition": "all correctness tests pass within tolerance"},
      {"from": "correctness_passed", "to": "profiled", "condition": "baseline profile captured"},
      {"from": "profiled", "to": "optimized", "condition": "profile experiment improves target metric"},
      {"from": "optimized", "to": "integrated", "condition": "framework binding tests pass"},
      {"from": "integrated", "to": "regression_guarded", "condition": "CI correctness and performance gates configured"}
    ]
  }
}
